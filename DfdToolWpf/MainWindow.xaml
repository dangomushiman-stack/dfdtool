<Window x:Class="DfdToolWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MVVM版 DFDエディタ" Height="600" Width="1100" KeyDown="Window_KeyDown" UseLayoutRounding="True">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#EEE" Height="40">
            <RadioButton Content="プロセス" Style="{StaticResource {x:Type ToggleButton}}" GroupName="ToolMode" Margin="5" Padding="10,0" Click="BtnMode_Click" Tag="Process" IsChecked="True" />
            <RadioButton Content="実体" Style="{StaticResource {x:Type ToggleButton}}" GroupName="ToolMode" Margin="5" Padding="10,0" Click="BtnMode_Click" Tag="Entity" />
            <RadioButton Content="破線実体" Style="{StaticResource {x:Type ToggleButton}}" GroupName="ToolMode" Margin="5" Padding="10,0" Click="BtnMode_Click" Tag="DashEntity" />
            <Rectangle Width="2" Fill="DarkGray" Margin="5"/>
            <RadioButton Content="接続枠" Style="{StaticResource {x:Type ToggleButton}}" GroupName="ToolMode" Margin="5" Padding="10,0" Click="BtnMode_Click" Tag="ConnectableFrame" Background="#E2F0FF" />
            <RadioButton Content="分類枠" Style="{StaticResource {x:Type ToggleButton}}" GroupName="ToolMode" Margin="5" Padding="10,0" Click="BtnMode_Click" Tag="CategoryFrame" Background="#E0FFE0" />
            <Rectangle Width="2" Fill="DarkGray" Margin="5"/>
            <RadioButton Content="データストア" Style="{StaticResource {x:Type ToggleButton}}" GroupName="ToolMode" Margin="5" Padding="10,0" Click="BtnMode_Click" Tag="DataStore" />
            <Rectangle Width="2" Fill="DarkGray" Margin="5"/>
            <RadioButton Content="↗️ 矢印" Style="{StaticResource {x:Type ToggleButton}}" GroupName="ToolMode" Margin="5" Padding="10,0" Click="BtnMode_Click" Tag="Arrow" Background="#DDF" />
            <Button Content="🗑️ 削除" Margin="5" Padding="10,0" Click="BtnDelete_Click" Foreground="DarkRed" />
            <Rectangle Width="2" Fill="DarkGray" Margin="5"/>
            <Button Content="クリア" Margin="5" Padding="10,0" Click="BtnClear_Click" Foreground="Red" />
            <Rectangle Width="2" Fill="DarkGray" Margin="5"/>
            <Button Content="💾 保存" Margin="5" Padding="10,0" Click="BtnSave_Click" />
            <Button Content="📂 読込" Margin="5" Padding="10,0" Click="BtnLoad_Click" />
            <Rectangle Width="2" Fill="DarkGray" Margin="5"/>
            <Button Content="🖼️ 画像出力" Margin="5" Padding="10,0" Click="BtnExportImage_Click" />
            
            <Rectangle Width="2" Fill="DarkGray" Margin="5"/>
            <CheckBox Content="グリッドスナップ" IsChecked="{Binding SnapToGrid}" VerticalAlignment="Center" Margin="5" FontWeight="Bold" />
        </StackPanel>

        <Grid x:Name="ViewportContainer" ClipToBounds="True">
            <Canvas x:Name="MainCanvas" Focusable="True" Background="Transparent" MouseLeftButtonDown="Canvas_MouseLeftButtonDown">
                
                <Canvas.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="MainScale" ScaleX="1" ScaleY="1" />
                        <TranslateTransform x:Name="MainTranslate" X="0" Y="0" />
                    </TransformGroup>
                </Canvas.RenderTransform>

                <Rectangle Canvas.Left="-50000" Canvas.Top="-50000" Width="100000" Height="100000" Panel.ZIndex="-100">
                    <Rectangle.Fill>
                        <DrawingBrush TileMode="Tile" Viewport="0,0,20,20" ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="White">
                                        <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,20,20"/></GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup><LineGeometry StartPoint="0,0" EndPoint="20,0"/><LineGeometry StartPoint="0,0" EndPoint="0,20"/></GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                        <GeometryDrawing.Pen><Pen Brush="#E5E5E5" Thickness="1"/></GeometryDrawing.Pen>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <ItemsControl ItemsSource="{Binding Connections}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Canvas TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
                                <Path Data="{Binding LineGeometry}" StrokeThickness="3" Cursor="Hand" MouseLeftButtonDown="ConnectionPath_MouseLeftButtonDown" MouseRightButtonDown="ConnectionPath_MouseRightButtonDown" Panel.ZIndex="0">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Stroke" Value="Black" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Stroke" Value="Orange" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                
                                <Polygon Points="{Binding ArrowPoints}" Panel.ZIndex="1">
                                    <Polygon.Style>
                                        <Style TargetType="Polygon">
                                            <Setter Property="Fill" Value="Black" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Fill" Value="Orange" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Polygon.Style>
                                </Polygon>

                                <ItemsControl ItemsSource="{Binding Waypoints}" Panel.ZIndex="10">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="10" Height="10" StrokeThickness="2" Cursor="Hand" MouseLeftButtonDown="Waypoint_MouseLeftButtonDown" MouseRightButtonDown="Waypoint_MouseRightButtonDown">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="White" />
                                                        <Setter Property="Stroke" Value="DodgerBlue" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Fill" Value="DodgerBlue"/>
                                                            </Trigger>
                                                            <DataTrigger Binding="{Binding IsJump}" Value="True">
                                                                <Setter Property="Fill" Value="Gold" />
                                                                <Setter Property="Stroke" Value="DarkOrange" />
                                                            </DataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsJump}" Value="True" />
                                                                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Fill" Value="DarkOrange" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                
                                <Grid Canvas.Left="{Binding MidX}" Canvas.Top="{Binding MidY}" Background="White" MinWidth="60" MinHeight="20" Cursor="Hand" MouseLeftButtonDown="ConnectionLabel_PreviewMouseLeftButtonDown" Panel.ZIndex="5">
                                    <TextBlock Text="{Binding Text}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" KeyDown="TextBox_KeyDown" LostFocus="TextBox_LostFocus" IsVisibleChanged="TextBox_IsVisibleChanged">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </Canvas>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding Nodes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Thumb DragStarted="Node_DragStarted" DragDelta="Node_DragDelta" PreviewMouseLeftButtonDown="Node_PreviewMouseLeftButtonDown">
                                <Thumb.Template>
                                    <ControlTemplate>
                                        <Grid Width="{Binding Width}" Height="{Binding Height}" Cursor="Hand" x:Name="NodeGrid" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType" Background="Transparent" ContextMenuOpening="NodeGrid_ContextMenuOpening">
                                            
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="実線にする" Click="MenuItem_Solid_Click"/>
                                                    <MenuItem Header="点線にする" Click="MenuItem_Dashed_Click"/>
                                                </ContextMenu>
                                            </Grid.ContextMenu>

                                            <Ellipse x:Name="ShapeProcess" Fill="White" Stroke="#4A90E2" StrokeThickness="2" Visibility="Collapsed">
                                                <Ellipse.Effect><DropShadowEffect Color="Gray" BlurRadius="5" ShadowDepth="2" Opacity="0.5"/></Ellipse.Effect>
                                            </Ellipse>
                                            
                                            <Rectangle x:Name="ShapeEntity" Fill="White" Stroke="#4A90E2" StrokeThickness="2" Visibility="Collapsed">
                                                <Rectangle.Effect><DropShadowEffect Color="Gray" BlurRadius="5" ShadowDepth="2" Opacity="0.5"/></Rectangle.Effect>
                                            </Rectangle>
                                            
                                            <Rectangle x:Name="ShapeFrame" Fill="{x:Null}" Stroke="Gray" StrokeThickness="1" Visibility="Collapsed" />
                                            <Rectangle x:Name="ShapeConnectableFrame" Fill="{x:Null}" Stroke="#4A90E2" StrokeThickness="2" Visibility="Collapsed" />
                                            
                                            <Border x:Name="ShapeDataStore" Background="White" BorderBrush="#4A90E2" BorderThickness="0,2,0,2" Visibility="Collapsed">
                                                <Border.Effect><DropShadowEffect Color="Gray" BlurRadius="5" ShadowDepth="2" Opacity="0.5"/></Border.Effect>
                                            </Border>
                                            
                                            <Border x:Name="SelectionHighlight" BorderBrush="Orange" BorderThickness="3" Visibility="Collapsed" Margin="-3" CornerRadius="5"/>
                                            
                                            <Grid Margin="5">
                                                <TextBlock Text="{Binding Text}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" x:Name="LabelText" TextWrapping="Wrap" TextAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                
                                                <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" KeyDown="TextBox_KeyDown" LostFocus="TextBox_LostFocus" IsVisibleChanged="TextBox_IsVisibleChanged" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" TextWrapping="Wrap" TextAlignment="Center">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                            </Grid>
                                            
                                            <Thumb x:Name="ResizeThumb" Width="15" Height="15" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" DragStarted="ResizeThumb_DragStarted" DragDelta="ResizeThumb_DragDelta" Visibility="Collapsed">
                                                <Thumb.Template>
                                                    <ControlTemplate>
                                                        <Grid Background="{x:Null}">
                                                            <Path Data="M 0 15 L 15 0 L 15 15 Z" Fill="Gray" Opacity="0.5"/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Grid>
                                        
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="Process">
                                                <Setter TargetName="ShapeProcess" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="Entity">
                                                <Setter TargetName="ShapeEntity" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="DashEntity">
                                                <Setter TargetName="ShapeEntity" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="ShapeEntity" Property="StrokeDashArray" Value="3 2" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="CategoryFrame">
                                                <Setter TargetName="ShapeFrame" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="LabelText" Property="VerticalAlignment" Value="Top"/>
                                                <Setter TargetName="LabelText" Property="HorizontalAlignment" Value="Left"/>
                                                <Setter TargetName="NodeGrid" Property="Panel.ZIndex" Value="-10"/>
                                                <Setter TargetName="NodeGrid" Property="Background" Value="{x:Null}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="ConnectableFrame">
                                                <Setter TargetName="ShapeConnectableFrame" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="LabelText" Property="VerticalAlignment" Value="Top"/>
                                                <Setter TargetName="LabelText" Property="HorizontalAlignment" Value="Left"/>
                                                <Setter TargetName="NodeGrid" Property="Panel.ZIndex" Value="-5"/>
                                                <Setter TargetName="NodeGrid" Property="Background" Value="{x:Null}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="DataStore">
                                                <Setter TargetName="ShapeDataStore" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter TargetName="SelectionHighlight" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="ResizeThumb" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            
                                            <DataTrigger Binding="{Binding IsDashed}" Value="True">
                                                <Setter TargetName="ShapeFrame" Property="StrokeDashArray" Value="4 4" />
                                                <Setter TargetName="ShapeConnectableFrame" Property="StrokeDashArray" Value="4 4" />
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Canvas>
        </Grid>
    </DockPanel>
</Window>